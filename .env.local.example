# ============================================================
# KAI-OS — Environment Configuration Template
# Krishna AI Links Pvt. Ltd.
# ============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.local.example .env.local
#   2. Fill in every value below in your .env.local
#   3. NEVER commit .env.local — it is gitignored
#   4. See docs/deployment.md for full setup instructions
# ============================================================

# ── SUPABASE (Primary Database + Auth) ───────────────────────
# Project dashboard: https://supabase.com/dashboard
# All three values are on: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── DIRECTOR REGISTRATION CODE ───────────────────────────────
# Secret code required at /register when creating a director account.
# Use a strong, random value (e.g.: openssl rand -hex 24)
# ROTATE this if any director account is compromised.
DIRECTOR_REGISTRATION_CODE=your-strong-random-director-code-here

# ── FOUNDER / ADMIN SETUP ────────────────────────────────────
# Used only by: scripts/createAdmin.js (one-time setup)
# Remove from .env.local after initial admin creation.
FOUNDER_PASSWORD=your_initial_admin_password_here

# ── GEMINI AI (Audit Report Generation) ──────────────────────
# Optional — only needed for /api/audit/generate-report
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── SENTRY (Error Tracking) — Optional ───────────────────────
# Get DSN: https://sentry.io → Project → Settings → Client Keys
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# ── PRODUCTION URL (for OG images / absolute links) ──────────
# Set this when deploying to production
# NEXT_PUBLIC_SITE_URL=https://kai.krishnaailinks.com
