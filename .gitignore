# ──────────────────────────────────────────────────────────────────────────────
# KAI-OS — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────────────────────────
/.next/
/out/
/build

# ── TypeScript / SWC cache ────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
.swc/

# ── Environment / Secrets ─────────────────────────────────────────────────────
# NEVER commit real credentials. Copy .env.local.example → .env.local.
.env.local
.env*.local
.env.development
.env.production
.env.test
# Allow the example template (no real secrets inside)
!.env.local.example

# ── Local-only credentials file (real values, human-readable) ─────────────────
CREDENTIALS.local.md

# ── Test artifacts ────────────────────────────────────────────────────────────
/coverage
/playwright-report
/test-results

# ── PWA service worker source maps (contain local build machine paths) ────────
public/sw.js.map
public/workbox-*.js.map

# ── Sentry generated files ────────────────────────────────────────────────────
.sentryclirc

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vercel

# ── Local-only project documentation ──────────────────────────────────────────
PROJECT_DOCUMENTATION.md
